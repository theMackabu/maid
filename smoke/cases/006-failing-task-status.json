{
  "id": "006-failing-task-status",
  "name": "failing task returns failing status",
  "files": {
    "maidfile": "[tasks.bad]\nscript = \"sh -c 'exit 7'\"\n"
  },
  "steps": [
    {
      "run": [
        "bad"
      ],
      "expect": {
